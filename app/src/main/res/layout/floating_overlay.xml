<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_pill"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/overlay_pill_bg"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:gravity="center_vertical"
    android:elevation="8dp">

    <!-- Instagram Section -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/img_ig"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_instagram"
            android:contentDescription="Instagram"
            android:layout_marginEnd="5dp" />

        <TextView
            android:id="@+id/text_ig_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#B0BEC5"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="24dp"
        android:background="#40FFFFFF"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp" />

    <!-- YouTube Section -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/img_yt"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_youtube"
            android:contentDescription="YouTube"
            android:layout_marginEnd="5dp" />

        <TextView
            android:id="@+id/text_yt_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#B0BEC5"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Space -->
    <View
        android:layout_width="12dp"
        android:layout_height="1dp" />

    <!-- Reset / Close Button -->
    <FrameLayout
        android:id="@+id/btn_reset_overlay"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:background="@drawable/reset_btn_bg"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↺"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="1dp" />
    </FrameLayout>

</LinearLayout>
